{
  "name": "habit-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:dev": "nodemon --watch server --ext ts --exec \"node --import tsx/esm server/index.ts\"",
    "server": "node --import tsx/esm server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4",
    "@prisma/client": "^5.22.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "nodemon": "^3.1.7",
    "sass": "^1.77.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
