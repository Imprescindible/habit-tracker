{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "outDir":           "./dist/server",
    "rootDir":          "./server",
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "src"]
}
